# === Required (for daily attendance / check-in) ===

# QR Code numeric value of your housing's checkpoint
# Used as the default/fallback when locations.yaml is absent
QR_CODE_VALUE=12345

# KKN site coordinates (latitude, longitude) and random-point radius in meters
# Used as the default/fallback when locations.yaml is absent
KKN_LOCATION_LATITUDE=-7.9347226
KKN_LOCATION_LONGITUDE=119.1788225
KKN_LOCATION_RADIUS_METERS=100

# Comma-separated usernames to check in (you + friends).
# The API only validates the access token, so one login checks in everyone.
# Include your own username here.
USERNAMES=your.username,friend1,friend2

# Your SIMASTER SSO credentials (used to obtain the access token for check-in)
SIMASTER_USERNAME=your.username
SIMASTER_PASSWORD=yourpassword

# === Optional: Multi-location check-in ===

# Path to the locations config file (default: locations.yaml)
# See locations.example.yaml for the format.
# If absent, falls back to the single QR_CODE_VALUE + KKN_LOCATION_* above.
# LOCATIONS_FILE=locations.yaml

# Alternatively, inline JSON (used when no yaml file exists):
# LOCATIONS={"locations":{"desa_a":{"qr_value":1,"latitude":1,"longitude":1,"radius":50}},"user_locations":{"alice":"desa_a"},"default_location":"desa_a"}

# === Optional: Group report (per-user reports for the whole group) ===

# JSON object mapping each username to their SIMASTER password.
# Required for --group-report (each user's logbook is only visible from their own session).
# In GitHub Actions, store this as a secret named SIMASTER_CREDENTIALS.
# Example: {"alice":"pass1","bob":"pass2"}
SIMASTER_CREDENTIALS=

# === Optional: AI for logbook drafting & report narrative ===

# AI provider: "ollama" (Ollama Cloud) or "gemini" (Google Gemini)
AI_PROVIDER=ollama

# --- Ollama Cloud (recommended, OpenAI-compatible endpoint) ---
OLLAMA_BASE_URL=https://your-ollama-cloud-endpoint.example.com
OLLAMA_API_KEY=your_ollama_api_key
OLLAMA_MODEL=qwen2.5
OLLAMA_TEMPERATURE=0.7

# --- Gemini (alternative provider) ---
# AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview

# === Optional: Google Drive report upload ===

# Full service-account JSON (multi-line). In GitHub Actions, store as a secret.
GDRIVE_SERVICE_ACCOUNT_JSON=
# The shared Drive folder ID where reports are uploaded under /{username}/{date}/
GDRIVE_FOLDER_ID=

# === Optional: headless / daily-run behavior ===

# Skip check-in if user already has an active session today (default: true)
IDEMPOTENT=true

# Add random 0-5s delay between usernames (default: false)
THROTTLE=true

# Shuffle the check-in order (default: true)
SHUFFLE=true

# Bounded retries on failure (default: 3)
MAX_RETRIES=3
RETRY_BACKOFF=2.0

# === Optional: logging & storage paths ===

LOG_DIR=logs
LOG_LEVEL=INFO
LOG_MAX_BYTES=1048576
LOG_BACKUP_COUNT=7

CACHE_DIR=.cache
REPORT_DIR=reports