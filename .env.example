# === Required (for daily attendance / check-in) ===

# QR Code numeric value of your housing's checkpoint
QR_CODE_VALUE=12345

# KKN site coordinates (latitude, longitude) and random-point radius in meters
KKN_LOCATION_LATITUDE=-7.9347226
KKN_LOCATION_LONGITUDE=119.1788225
KKN_LOCATION_RADIUS_METERS=100

# Comma-separated usernames to check in (you + friends).
# The API only validates the access token, so one login checks in everyone.
# Include your own username here.
USERNAMES=your.username,friend1,friend2

# Your SIMASTER SSO credentials (used to obtain the access token)
SIMASTER_USERNAME=your.username
SIMASTER_PASSWORD=yourpassword

# === Optional: AI for logbook drafting & report narrative ===

# AI provider: "ollama" (Ollama Cloud) or "gemini" (Google Gemini)
AI_PROVIDER=ollama

# --- Ollama Cloud (recommended, OpenAI-compatible endpoint) ---
OLLAMA_BASE_URL=https://your-ollama-cloud-endpoint.example.com
OLLAMA_API_KEY=your_ollama_api_key
OLLAMA_MODEL=qwen2.5
OLLAMA_TEMPERATURE=0.7

# --- Gemini (alternative provider) ---
# AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview

# === Optional: headless / daily-run behavior ===

# Skip check-in if user already has an active session today (default: true)
IDEMPOTENT=true

# Add random 0-5s delay between usernames (default: false)
THROTTLE=true

# Shuffle the check-in order (default: true)
SHUFFLE=true

# Bounded retries on failure (default: 3)
MAX_RETRIES=3
RETRY_BACKOFF=2.0

# === Optional: logging & storage paths ===

LOG_DIR=logs
LOG_LEVEL=INFO
LOG_MAX_BYTES=1048576
LOG_BACKUP_COUNT=7

CACHE_DIR=.cache
REPORT_DIR=reports